{
  "name": "@vidflow/electron",
  "version": "0.0.0",
  "private": true,
  "description": "VidFlow Electron GUI",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron:launch\"",
    "dev:main": "tsc -p src/main/tsconfig.json --watch",
    "dev:renderer": "vite",
    "dev:electron:launch": "electron dist/main/index.js",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vidflow/core": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0"
  }
}
